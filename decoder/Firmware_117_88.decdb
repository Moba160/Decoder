              <ct:item type="constant" value="100"/>
              <ct:item type="operator" value="/"/>
              <ct:item type="constant" value="255"/>
            </ct:valueCalculation>
            <ct:description language="de" text="Intensität der Quittierungsimpulse (ACK)" help="verbessert die Programmierbarkeit"/>
          </ct:cv>
          <ct:cv id="822" number="114" type="byte" possibleValues="0-100" defaultValue="0" mode="rw">
            <ct:valueCalculation unit="%">
              <ct:item type="self"/>
