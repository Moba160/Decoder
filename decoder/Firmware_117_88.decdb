              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="29" selection="bit:4" value="1"/>
              </ct:trigger>
            </ct:conditions>
          </ct:cv>
          <ct:cv id="801" number="6" type="byte" possibleValues="0-255" defaultValue="0" mode="rw">
            <ct:valueCalculation>
              <ct:item type="self"/>
              <ct:specialValue value="0">
                <ct:description language="de" text="deaktiviert"/>
                <ct:description language="en" text="disabled"/>
              </ct:specialValue>
            </ct:valueCalculation>
            <ct:description language="de" text="Mittengeschwindigkeit"/>
            <ct:conditions>
              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="29" selection="bit:4" value="1"/>
              </ct:trigger>
            </ct:conditions>
          </ct:cv>
          <ct:cv id="25" number="7" type="byte" possibleValues="0-255" defaultValue="88" mode="ro">
            <ct:description language="de" text="Softwareversion"/>
          </ct:cv>
          <ct:cv id="26" number="8" type="byte" possibleValues="0-255" defaultValue="117" mode="ro">
            <ct:description language="de" text="Herstellerkennung"/>
          </ct:cv>
          <ct:cv id="802" number="9" type="select" possibleValues="6-63;134-191" defaultValue="134" mode="rw">
            <ct:description language="de" text="Motoransteuerungsperiode"/>
            <ct:conditions>
              <ct:trigger value="notRelevant" target="partial:2112">
                <ct:condition type="relational" operation="equal" cv="9" selection="bit:7" value="1"/>
              </ct:trigger>
              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="137" selection="bit:7" value="1"/>
              </ct:trigger>
            </ct:conditions>
            <ct:partial number="2112" possibleValues="6-63">
              <ct:valueCalculation unit="Hz" digits="1">
                <ct:item type="constant" value="1953"/>
                <ct:item type="operator" value="/"/>
                <ct:item type="self"/>
              </ct:valueCalculation>
              <ct:description language="de" text="Motoransteuerungsfrequenz"/>
            </ct:partial>
            <ct:bit number="7" value="128">
              <ct:description language="de" text="16 kHz"/>
            </ct:bit>
          </ct:cv>
