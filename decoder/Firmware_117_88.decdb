            <ct:valueCalculation>
              <ct:item type="self"/>
            </ct:valueCalculation>
            <ct:description language="de" text="Pausendauer der Effekte" help="definiert die Zeit (Dauer) zwischen 2 Effekten"/>
          </ct:cv>
          <ct:cv id="833" number="116" type="select" possibleValues="0-31;64-95" defaultValue="0" mode="rw">
            <ct:description language="de" text="Rangiergang - ABC"/>
            <ct:conditions>
              <ct:trigger value="notRelevant" target="bit:4">
                <ct:condition type="relational" operation="equal" cv="116" selection="bit:3" value="0"/>
              </ct:trigger>
            </ct:conditions>
            <ct:bit number="0" value="1">
              <ct:description language="de" text="Anfahr- und Bremsverzögerung (CV3, CV4) ausschalten"/>
            </ct:bit>
            <ct:bit number="1" value="2">
              <ct:description language="de" text="maximale Geschwindigkeit wird halbiert"/>
            </ct:bit>
            <ct:bit number="2" value="4">
              <ct:description language="de" text="rückwärts nur 65% der maximalen Geschwindigkeit"/>
            </ct:bit>
            <ct:bit number="3" value="8">
              <ct:description language="de" text="Bremsen mit Diode aktiv"/>
            </ct:bit>
            <ct:bit number="4" value="16">
              <ct:description language="de" text="Bremsen mit Diode NICHT Richtungsabhängig"/>
            </ct:bit>
            <ct:bit number="6" value="64">
              <ct:description language="de" text="Zugbeeinflussung wirkt nicht bei Rangierfunktion (MAN)"/>
            </ct:bit>
          </ct:cv>
          <ct:cv id="834" number="117" type="select" possibleValues="0-12" defaultValue="0" mode="rw">
            <ct:description language="de" text="Abblenden"/>
