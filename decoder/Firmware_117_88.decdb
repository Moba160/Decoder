    <protocols>
      <protocol type="dcc" speedSteps="14;28;128" progModes="DirectByte;POM" options="RestrictedSpeedStepInstruction(MAN)">
        <resets>
          <reset cv="1" value="0">
            <ct:description language="all" text="Reset"/>
          </reset>
        </resets>
        <cvs>
          <ct:cv id="1" number="1" type="byte" possibleValues="1-127" defaultValue="3" pomWriteExclude="true" mode="rw">
            <ct:description language="de" text="Adresse kurz"/>
            <ct:conditions>
              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="29" selection="bit:5" value="1"/>
              </ct:trigger>
            </ct:conditions>
          </ct:cv>
          <ct:cv id="797" number="2" type="byte" possibleValues="0-255" defaultValue="2" mode="rw">
            <ct:valueCalculation>
              <ct:item type="self"/>
            </ct:valueCalculation>
            <ct:description language="de" text="Mindestgeschwindigkeit"/>
            <ct:conditions>
              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="29" selection="bit:4" value="1"/>
              </ct:trigger>
            </ct:conditions>
          </ct:cv>
          <ct:cv id="798" number="3" type="byte" possibleValues="0-255" defaultValue="4" mode="rw">
            <ct:valueCalculation>
              <ct:item type="self"/>
              <ct:specialValue value="0">
                <ct:description language="de" text="aus"/>
                <ct:description language="en" text="off"/>
              </ct:specialValue>
            </ct:valueCalculation>
            <ct:description language="de" text="Beschleunigungszeit"/>
          </ct:cv>
          <ct:cv id="799" number="4" type="byte" possibleValues="0-255" defaultValue="4" mode="rw">
            <ct:valueCalculation>
              <ct:item type="self"/>
              <ct:specialValue value="0">
                <ct:description language="de" text="aus"/>
                <ct:description language="en" text="off"/>
              </ct:specialValue>
            </ct:valueCalculation>
            <ct:description language="de" text="Bremszeit"/>
          </ct:cv>
          <ct:cv id="800" number="5" type="byte" possibleValues="0-255" defaultValue="255" mode="rw">
            <ct:valueCalculation>
              <ct:item type="self"/>
              <ct:specialValue value="0">
                <ct:description language="de" text="255"/>
              </ct:specialValue>
            </ct:valueCalculation>
            <ct:description language="de" text="Maximalgeschwindigkeit"/>
