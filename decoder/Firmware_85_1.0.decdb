      </protocol>
      <protocol type="mm" speedSteps="14" progModes="Track" options="CVsDCC">
        <resets>
          <reset cv="59" value="1">
            <ct:description language="all" text="Reset"/>
          </reset>
        </resets>
        <cvs>
          <ct:cv id="269" number="1" type="byte" possibleValues="1-255" defaultValue="3" pomWriteExclude="true" mode="rw">
            <ct:description language="de" text="Adresse kurz" help="Adressen größer als 127 sind nur im MM-Betrieb verwendbar"/>
            <ct:conditions>
              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="29" selection="bit:5" value="1"/>
              </ct:trigger>
            </ct:conditions>
          </ct:cv>
          <ct:cv id="660" number="2" type="byte" possibleValues="1-63" defaultValue="1" mode="rw">
            <ct:description language="de" text="Minimale Geschwindigkeit"/>
          </ct:cv>
          <ct:cv id="661" number="3" type="byte" possibleValues="1-63" defaultValue="2" mode="rw">
            <ct:description language="de" text="Anfahrverzögerung"/>
          </ct:cv>
          <ct:cv id="662" number="4" type="byte" possibleValues="1-63" defaultValue="2" mode="rw">
            <ct:description language="de" text="Bremsverzögerung"/>
          </ct:cv>
          <ct:cv id="663" number="5" type="byte" possibleValues="1-63" defaultValue="60" mode="rw">
            <ct:description language="de" text="Maximale Geschwindigkeit" help="muß größer als CV 2 sein"/>
          </ct:cv>
          <ct:cv id="664" number="6" type="byte" possibleValues="1-63" defaultValue="32" mode="rw">
            <ct:description language="de" text="Mittlere Geschwindigkeit"/>
          </ct:cv>
          <ct:cvGroup id="665" type="dccLongAddr" possibleValues="1-9999" defaultValue="2000" pomWriteExclude="true" mode="rw">
            <ct:description language="de" text="Adresse lang" help="Nur, wenn durch CV29 aktiviert"/>
            <ct:cv number="18" type="byte" possibleValues="0-255" defaultValue="208" mode="rw">
              <ct:description language="de" text="Niederwertiges Byte"/>
            </ct:cv>
            <ct:cv number="17" type="byte" possibleValues="192-231" defaultValue="199" mode="rw">
              <ct:description language="de" text="Höherwertiges Byte"/>
            </ct:cv>
          </ct:cvGroup>
          <ct:cv id="229" number="19" type="select" possibleValues="0-255" defaultValue="0" mode="rw">
            <ct:description language="de" text="Verbundadresse + Inverse Fahrtrichtung" help="0 = Inaktiv"/>
            <ct:conditions>
              <ct:trigger value="reset">
                <ct:condition type="relational" operation="equal" cv="19" selection="partial:249" value="0"/>
              </ct:trigger>
              <ct:trigger value="notRelevant" target="bit:7">
                <ct:condition type="relational" operation="equal" cv="19" selection="partial:249" value="0"/>
              </ct:trigger>
            </ct:conditions>
            <ct:partial number="249" possibleValues="0-127">
              <ct:description language="de" text="Verbundadresse"/>
            </ct:partial>
            <ct:bit number="7" value="128">
              <ct:description language="de" text="Fahrtrichtung invertieren"/>
            </ct:bit>
          </ct:cv>
          <ct:cv id="4" number="28" type="select" possibleValues="0-3" defaultValue="3" mode="rw">
            <ct:description language="de" text="Railcom Konfiguration"/>
            <ct:conditions>
              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="29" selection="bit:3" value="0"/>
              </ct:trigger>
            </ct:conditions>
            <ct:bit number="0" value="1">
              <ct:description language="de" text="Kanal 1 (CH1) für Adressen ein"/>
            </ct:bit>
            <ct:bit number="1" value="2">
              <ct:description language="de" text="Kanal 2 (CH2) für Daten ein"/>
            </ct:bit>
          </ct:cv>
          <ct:cv id="95" number="29" type="select" possibleValues="0-63" defaultValue="14" mode="rw">
            <ct:description language="de" text="Einstellungen"/>
            <ct:bit number="0" value="1">
              <ct:description language="de" text="Richtung umkehren"/>
            </ct:bit>
            <ct:bitSelection number="1" value="2">
              <ct:option value="0">
