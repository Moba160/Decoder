          <ct:cv id="672" number="49" type="select" possibleValues="0-23;32-55;64-87;96-119;128-151;160-183;192-215;224-247" defaultValue="32" mode="rw">
            <ct:description language="de" text="Lokdecoder-Konfiguration"/>
            <ct:bit number="0" value="1">
              <ct:description language="de" text="Motorregelung aus"/>
            </ct:bit>
            <ct:bitSelection number="1" value="2">
              <ct:option value="0">
                <ct:description language="de" text="Susi-Ausgang konfiguriert für Soundmodul"/>
              </ct:option>
              <ct:option value="1">
                <ct:description language="de" text="Susi-Ausgang konfiguriert für LISSY"/>
              </ct:option>
            </ct:bitSelection>
            <ct:bitSelection number="2" value="4">
              <ct:option value="0">
                <ct:description language="de" text="bremst bis auf 0 im Bremsabschnitt"/>
              </ct:option>
              <ct:option value="1">
                <ct:description language="de" text="bremst bis auf Fahrstufe gemäß CV 64"/>
              </ct:option>
            </ct:bitSelection>
            <ct:group number="0">
              <ct:option value="0">
                <ct:description language="de" text="Datenformat DCC und Motorola"/>
              </ct:option>
              <ct:option value="8">
                <ct:description language="de" text="Datenformat nur DCC"/>
              </ct:option>
              <ct:option value="16">
                <ct:description language="de" text="Datenformat nur Motorola"/>
              </ct:option>
            </ct:group>
            <ct:bit number="5" value="32">
              <ct:description language="de" text="Dimmung für A1 und A2 ein"/>
            </ct:bit>
            <ct:bit number="6" value="64">
              <ct:description language="de" text="Lichtanschlüsse tauschen"/>
            </ct:bit>
            <ct:bitSelection number="7" value="128">
              <ct:option value="0">
                <ct:description language="de" text="Bremsen nur mit Bremssignal"/>
              </ct:option>
              <ct:option value="1">
                <ct:description language="de" text="Bremsen mit analoger Spannung"/>
              </ct:option>
            </ct:bitSelection>
          </ct:cv>
          <ct:cv id="673" number="50" type="byte" possibleValues="0-32" defaultValue="16" mode="rw">
            <ct:valueCalculation unit="%">
              <ct:item type="self"/>
              <ct:item type="operator" value="*"/>
              <ct:item type="constant" value="100"/>
              <ct:item type="operator" value="/"/>
              <ct:item type="constant" value="32"/>
            </ct:valueCalculation>
            <ct:description language="de" text="Dimmung der Funktionsausgänge Licht, A1 und A2"/>
          </ct:cv>
          <ct:cv id="674" number="51" type="select" possibleValues="1-3" defaultValue="3" mode="rw">
            <ct:description language="de" text="Einstellung der analogen Betriebsart"/>
            <ct:conditions>
              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="29" selection="bit:2" value="0"/>
              </ct:trigger>
            </ct:conditions>
            <ct:group number="0">
              <ct:option value="1">
                <ct:description language="de" text="nur AC-Betrieb"/>
              </ct:option>
              <ct:option value="2">
                <ct:description language="de" text="nur DC-Betrieb"/>
              </ct:option>
              <ct:option value="3">
                <ct:description language="de" text="AC und DC Betrieb mit automatischer Erkennung"/>
              </ct:option>
            </ct:group>
          </ct:cv>
          <ct:cv id="671" number="53" type="byte" possibleValues="0-63" defaultValue="35" mode="rw">
            <ct:description language="de" text="Wiederholrate der Motorregelung"/>
            <ct:conditions>
              <ct:trigger value="notRelevant">
                <ct:condition type="relational" operation="equal" cv="49" selection="bit:0" value="0"/>
              </ct:trigger>
            </ct:conditions>
          </ct:cv>
