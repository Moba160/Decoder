          </ct:cv>
          <ct:cv id="680" number="60" type="select" possibleValues="0-7" defaultValue="0" mode="rw">
            <ct:description language="de" text="Überwachung der Ausgänge ausschalten"/>
            <ct:bit number="0" value="1">
              <ct:description language="de" text="Motor aus"/>
            </ct:bit>
            <ct:bit number="1" value="2">
              <ct:description language="de" text="Licht-, A1-, A2 aus"/>
            </ct:bit>
            <ct:bit number="2" value="4">
              <ct:description language="de" text="Temperatur aus"/>
            </ct:bit>
          </ct:cv>
          <ct:cv id="681" number="62" type="select" possibleValues="0-7" defaultValue="0" mode="rw">
            <ct:description language="de" text="Fehlerspeicher der Kurzschlussmeldungen, Temperaturüberw" help="Alle Haken entfernen um Fehlerspeicher zu resetten"/>
            <ct:bit number="0" value="1">
              <ct:description language="de" text="Motor"/>
            </ct:bit>
            <ct:bit number="1" value="2">
